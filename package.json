{
  "name": "typeforge-ts",
  "version": "1.0.0",
  "type": "module",
  "description": "Blazing-fast, zero-dependency TypeScript utility toolkit. Modern lodash replacement with perfect type inference, tree-shaking, and edge compatibility.",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./array": {
      "types": "./dist/types/array/index.d.ts",
      "import": "./dist/esm/array/index.js",
      "require": "./dist/cjs/array/index.js"
    },
    "./object": {
      "types": "./dist/types/object/index.d.ts",
      "import": "./dist/esm/object/index.js",
      "require": "./dist/cjs/object/index.js"
    },
    "./string": {
      "types": "./dist/types/string/index.d.ts",
      "import": "./dist/esm/string/index.js",
      "require": "./dist/cjs/string/index.js"
    },
    "./function": {
      "types": "./dist/types/function/index.d.ts",
      "import": "./dist/esm/function/index.js",
      "require": "./dist/cjs/function/index.js"
    },
    "./promise": {
      "types": "./dist/types/promise/index.d.ts",
      "import": "./dist/esm/promise/index.js",
      "require": "./dist/cjs/promise/index.js"
    },
    "./guard": {
      "types": "./dist/types/guard/index.d.ts",
      "import": "./dist/esm/guard/index.js",
      "require": "./dist/cjs/guard/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "scripts": {
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "build": "npm run clean && npm run build:esm && npm run build:cjs && npm run build:types",
    "clean": "node -e \"const fs=require('fs');if(fs.existsSync('dist'))fs.rmSync('dist',{recursive:true})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "utility", "utils", "typescript", "lodash", "es-toolkit",
    "array", "object", "string", "function", "promise",
    "zero-dependency", "tree-shakable", "modern",
    "type-safe", "edge-runtime", "lightweight",
    "chunk", "groupBy", "debounce", "throttle", "memoize",
    "pick", "omit", "merge", "camelCase", "snakeCase",
    "deepClone", "pipe", "compose"
  ],
  "author": "Avinash Velu <avinashvelu03@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Avinashvelu03/typeforge.git"
  },
  "bugs": { "url": "https://github.com/Avinashvelu03/typeforge/issues" },
  "homepage": "https://github.com/Avinashvelu03/typeforge#readme",
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  },
  "engines": { "node": ">=18.0.0" },
  "sideEffects": false
}
